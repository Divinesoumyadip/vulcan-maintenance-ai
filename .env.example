# Copy to .env (auto-loaded by vulcan/config.py) or export in your shell
ANTHROPIC_API_KEY=sk-ant-...your key...
# Optional overrides:
# ANTHROPIC_MODEL=claude-sonnet-4-5
# VULCAN_MAX_TOKENS=4096
# VULCAN_MAX_TOOL_ROUNDS=8

# ── v10 autonomy (all read at call time; sensible defaults) ──
# VULCAN_DAEMON_AUTOSTART=1        # autonomy is the DEFAULT; 0 to opt out
# VULCAN_DAEMON_INTERVAL=60        # seconds between unattended passes
# VULCAN_RUL_WARN_HOURS=72         # predicted failure < this -> WARNING
# VULCAN_RUL_CRIT_HOURS=24         # predicted failure < this -> CRITICAL
# VULCAN_WO_SLA_MIN=60             # OPEN CRITICAL order older -> SLA breach
# VULCAN_DAEMON_LLM=0              # 1: daemon attaches full agent diagnostic
# VULCAN_DAEMON_LLM_MAX_PER_HOUR=4 #    ...hard token-budget cap
# VULCAN_WEBHOOK_URL=              # optional Slack/Teams/SMS-gateway sink

# ── v11 production (see PRODUCTION.md for the full ops guide) ──
# VULCAN_DB_PATH=data/vulcan.db   # SQLite WAL store (orders/notifs/state)
# VULCAN_RETENTION_DAYS=30        # prune alert files + notif rows (0=off)
# VULCAN_MAX_ALERTS_PER_CYCLE=25  # alert-storm guard cap
# VULCAN_HEALTH_PORT=8799         # service /healthz JSON metrics (0=off)
# VULCAN_WEBHOOK_SECRET=          # HMAC-SHA256 X-Vulcan-Signature on POSTs
# VULCAN_LOG_LEVEL=INFO
# VULCAN_LOG_DIR=data/logs
